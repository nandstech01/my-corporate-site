{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Blog Generation Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Total Jobs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [
        {
          "rawSql": "SELECT count(*) as value FROM blog_jobs",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "title": "Completed Jobs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [
        {
          "rawSql": "SELECT count(*) as value FROM blog_jobs WHERE status = 'completed'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      }
    },
    {
      "title": "Failed Jobs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [
        {
          "rawSql": "SELECT count(*) as value FROM blog_jobs WHERE status = 'failed'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    },
    {
      "title": "Avg ML Score",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "targets": [
        {
          "rawSql": "SELECT coalesce(avg(ml_score), 0) as value FROM blog_jobs WHERE ml_score IS NOT NULL",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "green", "value": 60 }
            ]
          }
        }
      }
    },
    {
      "title": "Queue Size",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "targets": [
        {
          "rawSql": "SELECT count(*) as value FROM blog_topic_queue WHERE status IN ('new', 'notified')",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Active Models",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "targets": [
        {
          "rawSql": "SELECT count(*) as value FROM blog_ml_models WHERE is_active = true",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Jobs Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('day', created_at) as time, status, count(*) as value FROM blog_jobs GROUP BY 1, 2 ORDER BY 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "title": "ML Score Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "targets": [
        {
          "rawSql": "SELECT ml_score FROM blog_jobs WHERE ml_score IS NOT NULL ORDER BY ml_score",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "bucketSize": 10,
        "combine": false
      }
    },
    {
      "title": "Blog ML & SEO",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "collapsed": false
    },
    {
      "title": "Model Performance (MAE over time)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "rawSql": "SELECT created_at as time, model_type, mae as value FROM blog_ml_models ORDER BY created_at",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Feature Importance Top 10",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "rawSql": "SELECT key as feature, value::float as importance FROM blog_ml_models, jsonb_each_text(feature_importance) WHERE is_active = true ORDER BY value::float DESC LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "GSC Performance (Clicks)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "rawSql": "SELECT date as time, sum(clicks) as value FROM gsc_page_metrics WHERE page_path LIKE '/posts/%' GROUP BY date ORDER BY date",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Training Data Growth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('week', created_at) as time, count(*) as value FROM blog_ml_training_data GROUP BY 1 ORDER BY 1",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Topic Queue by Source",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 30 },
      "targets": [
        {
          "rawSql": "SELECT source_feed, count(*) as value FROM blog_topic_queue GROUP BY source_feed ORDER BY value DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Buzz Score Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 30 },
      "targets": [
        {
          "rawSql": "SELECT buzz_score FROM blog_topic_queue ORDER BY buzz_score",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Pipeline Step Duration",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 30 },
      "targets": [
        {
          "rawSql": "SELECT EXTRACT(EPOCH FROM (completed_at - started_at))/60 as duration_min, topic FROM blog_jobs WHERE completed_at IS NOT NULL ORDER BY created_at DESC LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["blog", "ml", "generation"],
  "templating": { "list": [] },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Tokyo",
  "title": "Blog Generation & ML",
  "uid": "blog-generation-ml",
  "version": 1,
  "weekStart": "monday"
}
